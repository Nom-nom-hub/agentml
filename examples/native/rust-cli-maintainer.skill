skill "rust-cli-maintainer" {
  version "0.4.0"
  description "Maintain Rust CLI behavior safely and professionally."
}

applies_to {
  paths [
    "src/commands/**"
    "src/cli.rs"
    "src/main.rs"
    "tests/**"
    "Cargo.toml"
  ]

  stacks ["Rust", "CLI"]

  keywords [
    "cli"
    "command"
    "flag"
    "output"
    "clap"
  ]
}

requires_validation [
  "cargo fmt --check"
  "cargo clippy --all-targets -- -D warnings"
  "cargo test"
]

rules {
  rule "Keep CLI output stable unless intentionally changed."
  rule "Add tests for every new command or flag."
  rule "Avoid unwrap in user-facing execution paths."
  rule "Update README and docs when command behavior changes."
}