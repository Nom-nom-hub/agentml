agent "rust-cli-maintainer" {
  version "0.4.0"
  description "Maintain Rust CLI behavior safely and professionally."

  purpose {
    human_goal "Maintain Rust CLI projects with AgentML contracts and validation."
    agent_goal "Modify Rust CLI code safely, add tests, and update documentation."
    non_goals [
      "Do not execute untrusted skills"
      "Do not expose secrets"
      "Do not publish without explicit approval"
    ]
  }

  context {
    stack ["Rust", "CLI"]
    important_files [
      "src/**"
      "tests/**"
      "Cargo.toml"
      "Cargo.lock"
    ]
  }

  permissions {
    read [
      "**/*.rs"
      "**/*.md"
      "Cargo.toml"
      "Cargo.lock"
    ]
    write [
      "src/**"
      "tests/**"
      "docs/**"
      "Cargo.toml"
      "Cargo.lock"
    ]
    forbidden [
      ".env"
      ".env.*"
      ".git/**"
      "target/**"
      "node_modules/**"
    ]
  }

  safety {
    forbidden_actions [
      "rm -rf"
      "git reset --hard"
      "git clean -fd"
      "cargo publish"
    ]
    forbidden_paths [
      ".env"
      ".env.*"
      "*.pem"
      "*.key"
    ]
  }

  validation {
    command "cargo fmt --check"
    command "cargo clippy --all-targets -- -D warnings"
    command "cargo test"
  }
}