agent "example-native" {
  version "0.4.0"
  description "Example native AgentML file"
}

purpose {
  human_goal "Demonstrate native AgentML syntax"
  agent_goal "Parse and validate native AgentML files"
  non_goals [
    "Do not execute untrusted code"
  ]
}

permissions {
  read [
    "**/*.rs"
    "**/*.md"
  ]
  write [
    "src/**"
    "docs/**"
  ]
}

safety {
  forbidden_actions [
    "rm -rf"
  ]
  forbidden_paths [
    ".env"
    ".git/**"
  ]
}

validation {
  command "cargo fmt --check"
  command "cargo test"
}