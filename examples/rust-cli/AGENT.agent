meta:
  name: "rust-cli-tool"
  version: "0.1.0"
  description: "Safe AI agent workspace for a Rust CLI file-processing tool"

purpose: >
  AI agent for developing and maintaining a Rust CLI file-processing tool
  with safety rules ensuring parser/validator changes include tests,
  preventing accidental publishes, and blocking destructive commands.

context:
  project_type: rust-cli
  languages: [rust]
  frameworks: [clap, anyhow, thiserror]

permissions:
  read:
    - "**/*.rs"
    - "**/Cargo.toml"
    - "**/*.md"
    - "**/*.toml"
    - "**/*.lock"
    - "tests/**"
  write:
    - "src/**/*.rs"
    - "tests/**/*.rs"
    - "Cargo.toml"
    - "docs/**"
  execute:
    - "cargo"
    - "rustfmt"
    - "cargo-clippy"

tools:
  - "cargo"
  - "rustfmt"
  - "git"
  - "bash"

safety:
  policy: "Never modify Cargo.lock without purpose. Never commit secrets."
  forbidden_paths:
    - ".env*"
    - "target/**"
    - "**/*.rs.bk"
  forbidden_actions:
    - "cargo publish"
    - "rm -rf src"
  require_confirmation:
    - "cargo publish"
    - "cargo install --path ."

validation:
  - name: "Format"
    command: "cargo fmt -- --check"
  - name: "Clippy"
    command: "cargo clippy --all-targets -- -D warnings"
  - name: "Test"
    command: "cargo test"
  - name: "Doc"
    command: "cargo doc --no-deps"

output:
  format: markdown
  required_sections:
    - "changes"
    - "tests"
    - "risks"
