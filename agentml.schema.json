{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentML Agent File",
  "type": "object",
  "required": ["purpose", "permissions", "safety", "validation", "output"],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "version"]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "object",
      "properties": {
        "project_type": { "type": "string" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "frameworks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "permissions": {
      "type": "object",
      "required": ["read"],
      "properties": {
        "read": { "type": "array", "items": { "type": "string" } },
        "write": { "type": "array", "items": { "type": "string" } },
        "execute": { "type": "array", "items": { "type": "string" } }
      }
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "steps"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "commands": { "type": "array", "items": { "type": "string" } },
                "success": { "type": "string" },
                "on_failure": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "workflow": { "type": "string" },
          "inputs": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "description": { "type": "string" },
                "required": { "type": "boolean" },
                "default": { "type": "string" }
              }
            }
          },
          "success": { "type": "string" }
        }
      }
    },
    "memory": { "type": "string" },
    "safety": {
      "type": "object",
      "required": ["forbidden_paths", "forbidden_actions"],
      "properties": {
        "policy": { "type": "string" },
        "forbidden_paths": { "type": "array", "items": { "type": "string" } },
        "forbidden_actions": { "type": "array", "items": { "type": "string" } },
        "require_confirmation": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "command"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["format"],
      "properties": {
        "format": { "type": "string" },
        "required_sections": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
