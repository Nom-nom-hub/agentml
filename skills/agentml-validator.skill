skill: agentml-validator
version: 0.2.2
description: Validate AGENT.agent and .skill files using AgentML semantic rules.

applies_to:
  paths:
    - AGENT.agent
    - "**/*.skill"
    - src/validator.rs
  stacks:
    - Rust
  keywords:
    - validate
    - contract
    - skill

risk:
  base_score: 10

requires_validation:
  - cargo fmt --check
  - cargo clippy --all-targets -- -D warnings
  - cargo test

actions:
  - parse_contract
  - validate_required_sections
  - validate_permissions
  - validate_safety_policy
  - validate_tasks
  - calculate_risk_score
  - emit_report

rules:
  - Missing purpose is an error.
  - Missing permissions is an error.
  - Missing validation commands is an error.
  - Missing success criteria is an error.
  - Forbidden paths must never be writable.
  - Destructive commands require explicit approval.

success: >
  Invalid contracts fail with clear errors.
  Valid contracts pass with zero errors.
  Risk score is included in the output.
  Suggested fixes are generated for warnings.

output: >
  Required fields: valid, errors, warnings, risk_score, suggested_fixes.
