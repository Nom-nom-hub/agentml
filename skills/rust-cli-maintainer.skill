skill: rust-cli-maintainer
version: 0.3.0
description: Maintain the AgentML Rust CLI safely.

applies_to:
  paths:
    - src/commands/**
    - src/cli.rs
    - src/main.rs
    - tests/**
  stacks:
    - Rust
    - CLI
  keywords:
    - command
    - cli
    - clap
    - output

risk:
  base_score: 15
  high_risk_paths:
    - src/commands/close.rs
    - src/commands/diff.rs
    - src/commands/doctor.rs

requires_validation:
  - cargo fmt --check
  - cargo clippy --all-targets -- -D warnings
  - cargo test

rules:
  - Keep CLI output stable unless intentionally changed.
  - Add tests for every new validation rule.
  - Avoid panics in user-facing parsing paths.
  - Prefer structured errors over unwrap.

success:
  "cargo fmt passes. cargo clippy passes. cargo test passes. CLI examples still work."

actions:
  - inspect_cli_commands
  - update_parser
  - update_validator
  - update_tests
  - run_cargo_checks

output:
  "Required fields: changed_modules, commands_run, test_result, compatibility_notes."