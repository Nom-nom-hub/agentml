skill: mcp-server-maintainer
version: 0.3.0
description: Maintain the MCP server for AgentML integration.

applies_to:
  paths:
    - src/mcp.rs
    - tests/mcp_tests.rs
    - docs/mcp.md
    - README.md
  keywords:
    - mcp
    - server
    - integration
    - tools

risk:
  base_score: 20
  high_risk_paths:
    - src/mcp.rs

requires_validation:
  - cargo fmt --check
  - cargo clippy --all-targets -- -D warnings
  - cargo test

rules:
  - No arbitrary shell execution.
  - Block path traversal and secret-looking paths.
  - Responses must be structured and stable.
  - Add or update tests for every MCP tool change.
  - Update docs/mcp.md when tools change.

success:
  "MCP server compiles and runs. All MCP tests pass. Docs are updated."

actions:
  - follow_rules
  - update_docs
  - validate_work

output:
  "Required fields: summary, files_changed, commands_run, validation_result, risk_score, commit, next_steps."