skill: release-auditor
version: 0.3.0
description: Audit AgentML before release.

applies_to:
  paths:
    - Cargo.toml
    - Cargo.lock
    - CHANGELOG.md
    - docs/release.md
    - .github/workflows/**
  keywords:
    - release
    - publish
    - crates.io

risk:
  base_score: 25
  high_risk_paths:
    - Cargo.toml
    - CHANGELOG.md

requires_validation:
  - cargo fmt --check
  - cargo clippy --all-targets -- -D warnings
  - cargo test
  - cargo publish --dry-run

rules:
  - Dry-run must verify the intended version.
  - Changelog release notes must be scoped to one version.
  - Tag must match package version.
  - Verify install after publish.
  - Working tree must be clean before release.

success:
  "Dry-run passes. Changelog is accurate. Tag is correct. Install works. Working tree is clean."

actions:
  - follow_rules
  - update_docs
  - validate_work

output:
  "Required fields: summary, files_changed, commands_run, validation_result, risk_score, commit, next_steps."