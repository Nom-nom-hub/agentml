skill: agentml-contract-validator
version: 0.3.0
description: Validate AGENT.agent and .skill files using AgentML semantic rules.

applies_to:
  paths:
    - AGENT.agent
    - "*.skill"
    - src/validator.rs
    - src/commands/validate.rs
    - src/commands/doctor.rs
    - docs/spec.md
  stacks:
    - Rust
  keywords:
    - validate
    - contract
    - skill

risk:
  base_score: 15

requires_validation:
  - cargo fmt --check
  - cargo clippy --all-targets -- -D warnings
  - cargo test

rules:
  - Invalid contracts must fail clearly.
  - Errors must explain what failed, why it matters, and the suggested fix.
  - Forbidden paths must never become writable.
  - docs/spec.md must match validator behavior.
  - Examples must validate.

success:
  "Invalid contracts fail with clear errors. Valid contracts pass with zero errors. Risk score is included in the output. Suggested fixes are generated for warnings."

actions:
  - follow_rules
  - update_docs
  - validate_work

output:
  "Required fields: valid, errors, warnings, risk_score, suggested_fixes."